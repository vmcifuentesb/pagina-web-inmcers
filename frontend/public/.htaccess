# Compresión Gzip para reducir peso de los archivos transferidos
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# Caché del Navegador para Recursos Estáticos (WPO)
<IfModule mod_expires.c>
  ExpiresActive On
  # Caché por defecto
  ExpiresDefault "access plus 1 month"
  
  # HTML no debe cachearse para reflejar actualizaciones inmediatamente
  ExpiresByType text/html "access plus 0 seconds"
  
  # CSS y JS optimizados con hash en el build
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  
  # Recursos multimedia
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Enrutamiento de SPA para React Router DOM (Evitar error 404 al recargar)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
